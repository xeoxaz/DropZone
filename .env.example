# DropZone Configuration

# Storage root directory (Linux mount path) - vault HDD
DROPZONE_STORAGE_ROOT=/mnt/vault-01

# Optional: automatically remove DB records for files missing on disk.
# Set 0 to disable. Default is 60000 (1 minute).
DROPZONE_GHOST_REFRESH_MS=60000

# Optional: collapse duplicate upload_records for identical file/operator/mode
# created within this window (seconds). Set 0 to disable.
DROPZONE_UPLOAD_DEDUP_WINDOW_SECONDS=15
